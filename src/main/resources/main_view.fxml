<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.panda.goals_list.controller.MainController">

    <Label text="Новая цель:" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <TextField fx:id="nameField" promptText="Название (например, Ноут для Kali)" maxWidth="250"/>
    <TextField fx:id="amountField" promptText="Сумма (например, 45000)" maxWidth="250"/>
    <Button text="Добавить цель" onAction="#onAddGoalClicked" style="-fx-font-size: 14px;"/>

    <Label fx:id="resultLabel" text="" style="-fx-text-fill: green; -fx-font-size: 14px;"/>

    <Label text="Прогресс:" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 20 0 0 0;"/>

    <ProgressBar fx:id="progressBar" progress="0.0" prefWidth="250" prefHeight="20"/>
    <Label fx:id="progressTextLabel" text="0 / 0" style="-fx-font-size: 14px;"/>

    <HBox alignment="CENTER" spacing="10.0">
        <TextField fx:id="depositField" promptText="Сумма пополнения" maxWidth="150"/>
        <Button text="Пополнить" onAction="#onDepositClicked"/>
    </HBox>

</VBox>